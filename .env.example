# Resend — get a key from https://resend.com/api-keys
RESEND_API_KEY=

# Sender. The Resend sandbox sender works without domain verification.
RESEND_FROM_EMAIL=onboarding@resend.dev

# OpenAI — powers the "ask agent" inline composer in the toolbar.
# Get one from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model to use. Cheap default; bump to gpt-4o for higher design quality.
OPENAI_MODEL=gpt-4o-mini

# Scheduler backend.
#   "temporal" — durable workflow engine. Local dev story; needs
#                `temporal server start-dev` running and the worker
#                spawned by `npm run dev`.
#   "resend"   — Resend's native scheduledAt. Zero-infra, serverless-
#                friendly. Up to 30 days in advance. Auto-selected on
#                Vercel.
# If unset: temporal locally, resend on Vercel.
SCHEDULER=temporal

# Temporal dev server (run: temporal server start-dev)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=emails
